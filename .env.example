# Copy to .env in this directory (gitignored). Used by ./run.sh and ./build.sh
# to pass -ldflags embeds; you can also export these variables in your shell.

TRAY_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
TRAY_SUPABASE_ANON_KEY=your-publishable-anon-key

# Optional: skip the browser provider picker and use this id (e.g. google, github).
# TRAY_OAUTH_PROVIDER=google

# Optional: print full PostgREST error JSON (useful when debugging 4xx/5xx from the Data API).
# TRAY_DEBUG=1

# Maintainer-only: set to 1 so ./run.sh / ./build.sh embed OAuth redirect diagnostics in the binary.
# Do not set in release builds for end users. Not read at runtime.
# TRAY_EMBED_DEV_OAUTH_HINTS=1

# Optional: local `supabase functions serve gateway` — mirror secrets from the Supabase dashboard.
# Not read by the tray CLI binary.
# SUPABASE_SERVICE_ROLE_KEY=
# GATEWAY_JWT_SECRET=
# GATEWAY_TOKEN_ISSUER=tray-gateway
# GATEWAY_TOKEN_AUDIENCE=chatgpt
# GATEWAY_OAUTH_PROVIDER=google
# GATEWAY_ALLOWED_CLIENT_IDS=chatgpt-gateway-dev
# ChatGPT Action OAuth scope: use "tray.read tray.write" so the gateway JWT allows mutations (add/delete/triage).
# GATEWAY_ALLOWED_REDIRECT_PREFIXES=https://chat.openai.com/,https://chatgpt.com/

