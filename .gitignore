# Local brainstorming / specs — never commit anything under scratch/ (no exceptions).
# Promote notes into README.md, docs/, or code. Do not `git add -f` here.
scratch/

# Local comms drafts (e.g. Slack copy); not product docs.
docs/drafts/

# Go build artifact when built from repo root
/tray

# Release tarballs from scripts/build-release.sh
/dist/

# Generated CLI report (scripts/generate-cli-report.sh)
/tmp/

# Local env (secrets)
.env
.env.*
!.env.example

# Dolt database files (added by bd init)
.dolt/
*.db

# Go coverage (from `make test-cover` or `go test -coverprofile=...`)
coverage.out
coverage.html
